<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.njcit.mapper.AttendClassSettingMapper">
    <select id="getAttendClassSettingById" resultType="cn.njcit.entity.AttendClassSetting">
        select *
        from aoa_attend_class_setting
        where id = #{id}
    </select>

    <select id="getAllSettings" resultType="cn.njcit.entity.AttendClassSetting">
        select *
        from aoa_attend_class_setting
        where del_flag = 0
        order by id desc
    </select>

    <select id="searchSettings" resultType="cn.njcit.entity.AttendClassSetting">
        select *
        from aoa_attend_class_setting
        where del_flag = 0
          and (address like "%"#{searchName}"%" or attend_class_week like "%"#{searchName}"%")
        order by id desc
    </select>
</mapper>
